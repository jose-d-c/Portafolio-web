---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { parciales } from "../../parciales/parciales";

export function getStaticPaths() {
  return parciales.map((parcial) => ({
    params: { slug: parcial.slug },
    props: { parcial },
  }));
}

const { parcial } = Astro.props;
---

<BaseLayout title={`${parcial.titulo} | Parciales`}>
  <main class="app-shell parcial-shell">
    <section class="panel encabezado-parcial">
      <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
      <div>
        <p class="eyebrow">Evaluaciones academicas</p>
        <h1>{parcial.titulo}</h1>
        <p>{parcial.descripcion}</p>
      </div>
      <a class="icono-volver" href="/" aria-label="Volver al menu principal" title="Volver al menu principal">
        <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
      </a>
    </section>

    <section class="panel subpanel">
      <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Puntos del parcial</h2>
      <p class="textoSuave">Selecciona un punto para ver su descripcion, plantilla de codigo y su output.</p>

      <div class="grilla-puntos">
        {parcial.puntos.map((punto) => (
          <a class="tarjeta-punto" href={`/parciales/${parcial.slug}/${punto.slug}`}>
            <h3>{punto.nombre}</h3>
            <p>{punto.descripcion}</p>
            <span>Ver punto</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
.parcial-shell{ max-width: 1260px; display: grid; gap: 1.1rem; }
.encabezado-parcial{ display: grid; grid-template-columns: 110px 1fr auto; gap: 1.2rem; padding: 1.4rem; align-items: center; }
.encabezado-parcial > img{ width: 100%; max-width: 110px; border-radius: .8rem; background: #fff; padding: 6px; border: 1px solid var(--line); }
.encabezado-parcial h1{ font-size: clamp(1.8rem, 3vw, 2.6rem); margin-bottom: .5rem; }
.icono-volver{ width: 3.7rem; height: 3.7rem; border-radius: .8rem; border: 1px solid var(--line); background: var(--panel); color: var(--text); display: inline-flex; align-items: center; justify-content: center; }
.icono-volver .ui-icon{ margin-right: 0; width: 1.9rem; height: 1.9rem; }
h2{ margin-top: 0; display: inline-flex; align-items: center; }
.grilla-puntos{ margin-top: .8rem; display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1rem; }
.tarjeta-punto{ border: 1px solid var(--line); border-radius: .8rem; padding: 1rem; text-decoration: none; color: var(--text); background: var(--panel); display: grid; gap: .6rem; }
.tarjeta-punto h3{ margin: 0; }
.tarjeta-punto p{ margin: 0; color: var(--textSoft); }
.tarjeta-punto span{ font-weight: 600; color: var(--accent); }
@media (max-width: 900px){ .encabezado-parcial{ grid-template-columns: 1fr; justify-items: center; text-align: center; } .grilla-puntos{ grid-template-columns: 1fr; } }
</style>
