        bubblePlus: { int: "/programas-temporales/programa-05", string: "/programas-temporales/programa-06" },
        selection: { int: "/programas-temporales/programa-11", string: "/programas-temporales/programa-12" },
        insertion: { int: "/programas-temporales/programa-15", string: "/programas-temporales/programa-16" },
        shell: { int: "/programas-temporales/programa-09", string: "/programas-temporales/programa-10" },
        shaker: { int: "/programas-temporales/programa-18", string: "/programas-temporales/programa-19" },
