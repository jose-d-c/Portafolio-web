        tablaBody.innerHTML = state.resultados
          .map((resultado) => {
            const pasoIndice = Math.min(state.pasoActual, resultado.steps.length - 1);
            const paso = resultado.steps[pasoIndice] ?? resultado.steps[resultado.steps.length - 1];
            const enlacePrograma = enlacesProgramas[resultado.id]?.[state.tipoDato];
            const programaCell = enlacePrograma
              ? `<a class="tabla-link" href="${enlacePrograma}" target="_blank" rel="noreferrer">Abrir</a>`
              : '<span class="tabla-link disabled">No encontrado</span>';
            return `
              <tr class="sim-row ${resultado.id === state.algoritmoActivo ? "activo" : ""}" style="--alg-color:${resultado.color}">
                <td>${resultado.nombre}</td>
                <td>${Math.min(state.pasoActual + 1, resultado.steps.length)}</td>
                <td>${paso?.comparaciones ?? 0}</td>
                <td>${paso?.intercambios ?? 0}</td>
                <td>${paso?.iteraciones ?? 0}</td>
                <td>${resultado.tiempoMs.toFixed(2)}</td>
                <td>${resultado.memoria.toFixed(1)}</td>
                <td>${resultado.usaRecursion ? "Sí" : "No"}</td>
                <td>${resultado.estable ? "Estable" : "Inestable"}</td>
                <td>${programaCell}</td>
              </tr>
            `;
          })
          .join("");
      };

      const renderVisual = () => {
        if (!state.resultados.length) {
          visualStage.innerHTML = '<p class="sim-placeholder">Inicia la simulación para ver las barras en movimiento.</p>';
          visualStage.dataset.view = "bars";
          return;
        }
        const activo = state.resultados.find((item) => item.id === state.algoritmoActivo) ?? state.resultados[0];
        const pasoIndice = Math.min(state.pasoActual, activo.steps.length - 1);
        const paso = activo.steps[pasoIndice];
        if (!paso) {
          visualStage.innerHTML = '<p class="sim-placeholder">Crea una nueva simulación para ver resultados.</p>';
          visualStage.dataset.view = "bars";
          return;
        }
        if (paso.vista === "tree" && paso.tree) {
          renderTreeView(paso.tree);
        } else {
          renderBarsView(paso, activo);
        }
        renderLog(paso.descripcion, pasoIndice, activo.steps.length);
      };

      const updateUi = () => {
        renderTabla();
        renderVisual();
        renderDescripcion();
        updateTimeline();
      };

      const scheduleTick = () => {
        if (state.temporizador) {
          clearTimeout(state.temporizador);
          state.temporizador = null;
        }
        if (!state.jugando) return;
        state.temporizador = window.setTimeout(() => {
          if (state.pasoActual < state.maxPasos - 1) {
            state.pasoActual += 1;
            updateUi();
            scheduleTick();
          } else {
            detenerAnimacion();
            setStatus("Finalizado");
          }
        }, state.velocidad);
      };

      const estimarMemoria = (id, n) => {
        switch (id) {
          case "merge":
            return n * 8;
          case "quick":
            return Math.log2(n + 1) * 64;
          case "heap":
            return n * 4;
          default:
            return n * 2;
        }
      };

      const prepararSimulacion = () => {
        colorCache.clear();
        const dataset = generarDataset(state.tipoDato, state.escenario, state.cantidad);
        const resultados = Object.entries(ALGORITMOS).map(([id, meta]) => {
          const copia = dataset.map(clonarPunto);
          const inicio = performance.now();
          const steps = meta.ejecutar(copia);
          const fin = performance.now();
          return {
            id,
            nombre: meta.nombre,
            color: meta.color,
            estable: meta.estable,
            usaRecursion: meta.usaRecursion,
            steps,
            tiempoMs: fin - inicio,
            memoria: estimarMemoria(id, copia.length)
          };
        });
        state.resultados = resultados;
        state.pasoActual = 0;
        state.maxPasos = Math.max(...resultados.map((r) => r.steps.length), 1);
        configEstado.textContent = `Listo: ${state.cantidad} datos (${tipoEtiqueta[state.tipoDato]} · ${ESCENARIOS[state.escenario].titulo}).`;
        updateUi();
      };

      const generarDataset = (tipoDato, escenario, cantidad) => {
        const base = Array.from({ length: cantidad }, (_, index) => {
          const valor = index + 1;
          if (tipoDato === "string") {
            const letra = String.fromCharCode(65 + (index % 26));
            const sufijo = (index % 100).toString().padStart(2, "0");
            return { value: valor, label: `${letra}${sufijo}` };
          }
          return { value: valor, label: valor.toString().padStart(2, "0") };
        });

        if (escenario === "invertido") {
          return [...base].reverse();
        }

        if (escenario === "intercalado") {
          const mezcla = [];
          const mitad = Math.ceil(base.length / 2);
          for (let i = 0; i < mitad; i++) {
            if (base[i]) mezcla.push(base[i]);
            if (base[i + mitad]) mezcla.push(base[i + mitad]);
          }
          return mezcla;
        }

        if (escenario === "parcial") {
          const copia = [...base];
          for (let i = 0; i < copia.length; i += 5) {
            const j = Math.min(copia.length - 1, i + 3);
            [copia[i], copia[j]] = [copia[j], copia[i]];
          }
          return copia;
        }

        const mezcla = [...base];
        for (let i = mezcla.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [mezcla[i], mezcla[j]] = [mezcla[j], mezcla[i]];
        }
        return mezcla;
      };

      const crearEstadisticas = () => ({ comparaciones: 0, intercambios: 0, iteraciones: 0 });
      const clonarPunto = (item) => ({ value: item.value, label: item.label });
      const crearPaso = (items, stats, descripcion, extras = {}) => ({
        items: items.map(clonarPunto),
        comparaciones: stats.comparaciones,
        intercambios: stats.intercambios,
        iteraciones: stats.iteraciones,
        descripcion,
        vista: extras.vista ?? "bars",
        tree: extras.tree ?? null,
        resaltados: extras.resaltados ?? []
      });

      const construirTreeHeap = (items, tamanio, resaltados = []) => {
        const niveles = [];
        let nivelActual = 0;
        let elementosEnNivel = 1;
        let indice = 0;
        while (indice < tamanio) {
          const nivel = [];
          for (let j = 0; j < elementosEnNivel && indice < tamanio; j++) {
            nivel.push({ label: items[indice].label, highlight: resaltados.includes(indice) });
            indice++;
          }
          niveles.push(nivel);
          nivelActual++;
          elementosEnNivel = Math.pow(2, nivelActual);
        }
        return { niveles };
      };

      const construirTreeBuckets = (buckets) => {
        const header = buckets.map((bucket, idx) => ({
          label: `B${idx + 1} (${bucket.length})`,
          highlight: bucket.length > 0
        }));
        const filas = buckets.map((bucket) => (bucket.length ? bucket.map((item) => ({ label: item.label })) : [{ label: "—" }]));
        return { niveles: [header, ...filas] };
      };

      const construirTreeRadix = (buckets, nivel) => {
        const encabezado = buckets.map((bucket, idx) => ({ label: `D${idx}`, highlight: bucket.length > 0 }));
        const detalle = buckets.map((bucket) => (bucket.length ? bucket.map((item) => ({ label: item.label })) : [{ label: "vacío" }]));
        return { niveles: [[{ label: `Dígito ${nivel}` }], encabezado, ...detalle] };
      };

      const construirTreeContador = (contador) => {
        if (!contador.length) return { niveles: [[{ label: "Sin datos" }]] };
        const segmentos = Math.min(10, contador.length);
        const rango = Math.ceil(contador.length / segmentos);
        const nodos = [];
        for (let i = 0; i < segmentos; i++) {
          const inicio = i * rango;
          if (inicio >= contador.length) break;
          const fin = Math.min(contador.length - 1, inicio + rango - 1);
          const suma = contador.slice(inicio, fin + 1).reduce((acc, val) => acc + val, 0);
          nodos.push({ label: `${inicio}-${fin}: ${suma}`, highlight: suma > 0 });
        }
        return { niveles: [nodos] };
      };

      function instrumentarBurbuja(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        for (let i = 0; i < items.length - 1; i++) {
          let huboCambio = false;
          for (let j = 0; j < items.length - 1 - i; j++) {
            stats.comparaciones++;
            if (items[j].value > items[j + 1].value) {
              [items[j], items[j + 1]] = [items[j + 1], items[j]];
              stats.intercambios++;
              huboCambio = true;
              pasos.push(crearPaso(items, stats, `Intercambio entre posiciones ${j + 1} y ${j + 2}`));
            }
            stats.iteraciones++;
          }
          if (!huboCambio) break;
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Los datos ya estaban ordenados"));
        return pasos;
      }

      function instrumentarBurbujaPlus(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        let ultimaPosicion = items.length - 1;
        while (ultimaPosicion > 0) {
          let nuevoLimite = 0;
          for (let j = 0; j < ultimaPosicion; j++) {
            stats.comparaciones++;
            if (items[j].value > items[j + 1].value) {
              [items[j], items[j + 1]] = [items[j + 1], items[j]];
              stats.intercambios++;
              nuevoLimite = j;
              pasos.push(crearPaso(items, stats, `Intercambio optimizado en ${j + 1}`, { resaltados: [j, j + 1] }));
            }
            stats.iteraciones++;
          }
          if (nuevoLimite === 0) break;
          ultimaPosicion = nuevoLimite;
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Arreglo ya estaba ordenado"));
        return pasos;
      }

      function instrumentarSeleccion(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        for (let i = 0; i < items.length - 1; i++) {
          let min = i;
          for (let j = i + 1; j < items.length; j++) {
            stats.comparaciones++;
            if (items[j].value < items[min].value) {
              min = j;
            }
          }
          if (min !== i) {
            [items[i], items[min]] = [items[min], items[i]];
            stats.intercambios++;
          }
          stats.iteraciones++;
          pasos.push(crearPaso(items, stats, `Posicion ${i + 1} lista`, { resaltados: [i, min] }));
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Arreglo trivial"));
        return pasos;
      }

      function instrumentarInsercion(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        for (let i = 1; i < items.length; i++) {
          const clave = items[i];
          let j = i - 1;
          stats.iteraciones++;
          while (j >= 0 && items[j].value > clave.value) {
            stats.comparaciones++;
            items[j + 1] = items[j];
            j -= 1;
            stats.intercambios++;
            pasos.push(crearPaso(items, stats, `Desplazando ${items[j + 1].label}`, { resaltados: [j + 1, j + 2] }));
          }
          if (j >= 0) stats.comparaciones++;
          items[j + 1] = clave;
          pasos.push(crearPaso(items, stats, `Insertando ${clave.label}`, { resaltados: [j + 1] }));
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Dataset minimo"));
        return pasos;
      }

      function instrumentarShell(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        for (let gap = Math.floor(items.length / 2); gap > 0; gap = Math.floor(gap / 2)) {
          for (let i = gap; i < items.length; i++) {
            const temp = items[i];
            let j = i;
            while (j >= gap && items[j - gap].value > temp.value) {
              stats.comparaciones++;
              items[j] = items[j - gap];
              j -= gap;
              stats.intercambios++;
              pasos.push(crearPaso(items, stats, `Gap ${gap}: desplazando ${temp.label}`, { resaltados: [j, j + gap] }));
            }
            if (j >= gap) stats.comparaciones++;
            items[j] = temp;
            stats.iteraciones++;
            pasos.push(crearPaso(items, stats, `Gap ${gap}: insertando ${temp.label}`));
          }
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Gap final sin cambios"));
        return pasos;
      }

      function instrumentarShaker(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        let inicio = 0;
        let fin = items.length - 1;
        let intercambio = true;
        while (inicio < fin && intercambio) {
          intercambio = false;
          for (let i = inicio; i < fin; i++) {
            stats.comparaciones++;
            if (items[i].value > items[i + 1].value) {
              [items[i], items[i + 1]] = [items[i + 1], items[i]];
              stats.intercambios++;
              intercambio = true;
            }
            stats.iteraciones++;
            pasos.push(crearPaso(items, stats, `Recorrido ➝ ${i + 1}`, { resaltados: [i, i + 1] }));
          }
          fin--;
          if (!intercambio) break;
          intercambio = false;
          for (let i = fin; i > inicio; i--) {
            stats.comparaciones++;
            if (items[i - 1].value > items[i].value) {
              [items[i], items[i - 1]] = [items[i - 1], items[i]];
              stats.intercambios++;
              intercambio = true;
            }
            stats.iteraciones++;
            pasos.push(crearPaso(items, stats, `Recorrido ⬅ ${i}`, { resaltados: [i - 1, i] }));
          }
          inicio++;
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Sin movimientos"));
        return pasos;
      }

      function instrumentarMerge(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        const buffer = Array(items.length);

        const mergeSort = (inicio, fin) => {
          if (inicio >= fin) return;
          const medio = Math.floor((inicio + fin) / 2);
          mergeSort(inicio, medio);
          mergeSort(medio + 1, fin);
          mezclar(inicio, medio, fin);
          pasos.push(crearPaso(items, stats, `Mezcla ${inicio + 1}-${fin + 1}`));
        };

        const mezclar = (inicio, medio, fin) => {
          let i = inicio;
          let j = medio + 1;
          let k = 0;
          while (i <= medio && j <= fin) {
            stats.comparaciones++;
            if (items[i].value <= items[j].value) {
              buffer[k++] = items[i++];
            } else {
              buffer[k++] = items[j++];
              stats.intercambios++;
            }
            stats.iteraciones++;
          }
          while (i <= medio) {
            buffer[k++] = items[i++];
            stats.iteraciones++;
          }
          while (j <= fin) {
            buffer[k++] = items[j++];
            stats.iteraciones++;
          }
          for (let idx = 0; idx < k; idx++) {
            items[inicio + idx] = buffer[idx];
          }
        };

        mergeSort(0, items.length - 1);
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Dataset minimo"));
        return pasos;
      }

      function instrumentarQuick(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];

        const quickSort = (inicio, fin) => {
          if (inicio >= fin) return;
          const pivoteIndex = particion(inicio, fin);
          pasos.push(crearPaso(items, stats, `Pivote colocado en posicion ${pivoteIndex + 1}`, { resaltados: [pivoteIndex] }));
          quickSort(inicio, pivoteIndex - 1);
          quickSort(pivoteIndex + 1, fin);
        };

        const particion = (inicio, fin) => {
          const pivote = items[fin];
          let i = inicio;
          for (let j = inicio; j < fin; j++) {
            stats.comparaciones++;
            if (items[j].value < pivote.value) {
              if (i !== j) {
                [items[i], items[j]] = [items[j], items[i]];
                stats.intercambios++;
              }
              i++;
            }
            stats.iteraciones++;
            pasos.push(crearPaso(items, stats, `Comparando con pivote ${pivote.label}`, { resaltados: [i, j, fin] }));
          }
          [items[i], items[fin]] = [items[fin], items[i]];
          stats.intercambios++;
          return i;
        };

        quickSort(0, items.length - 1);
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Dataset minimo"));
        return pasos;
      }

      function instrumentarHeap(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        const n = items.length;

        const heapify = (tamanio, indice) => {
          let mayor = indice;
          const izquierda = 2 * indice + 1;
          const derecha = 2 * indice + 2;
          if (izquierda < tamanio) {
            stats.comparaciones++;
            if (items[izquierda].value > items[mayor].value) {
              mayor = izquierda;
            }
          }
          if (derecha < tamanio) {
            stats.comparaciones++;
            if (items[derecha].value > items[mayor].value) {
              mayor = derecha;
            }
          }
          if (mayor !== indice) {
            [items[indice], items[mayor]] = [items[mayor], items[indice]];
            stats.intercambios++;
            pasos.push(crearPaso(items, stats, `Heapify sobre indice ${indice + 1}`, { resaltados: [indice, mayor], tree: construirTreeHeap(items, tamanio, [indice, mayor]), vista: "tree" }));
            heapify(tamanio, mayor);
          }
          stats.iteraciones++;
        };

        for (let i = Math.floor(n / 2) - 1; i >= 0; i--) {
          heapify(n, i);
        }
        for (let i = n - 1; i > 0; i--) {
          [items[0], items[i]] = [items[i], items[0]];
          stats.intercambios++;
          pasos.push(crearPaso(items, stats, `Extraido maximo hacia la posicion ${i + 1}`, { resaltados: [0, i], tree: construirTreeHeap(items, i, [0]), vista: "tree" }));
          heapify(i, 0);
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Dataset minimo"));
        return pasos;
      }

      function ordenarInsercionLigero(arr) {
        for (let i = 1; i < arr.length; i++) {
          const clave = arr[i];
          let j = i - 1;
          while (j >= 0 && arr[j].value > clave.value) {
            arr[j + 1] = arr[j];
            j--;
          }
          arr[j + 1] = clave;
        }
        return arr;
      }

      function instrumentarBucket(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        const bucketCount = Math.max(3, Math.ceil(Math.sqrt(items.length)));
        const maxValor = Math.max(...items.map((item) => item.value), 1);
        const buckets = Array.from({ length: bucketCount }, () => []);

        items.forEach((item) => {
          const indice = Math.min(bucketCount - 1, Math.floor((item.value / maxValor) * bucketCount));
          buckets[indice].push(clonarPunto(item));
          stats.iteraciones++;
          pasos.push(crearPaso(items, stats, `Elemento ${item.label} entra a bucket ${indice + 1}`, { vista: "tree", tree: construirTreeBuckets(buckets) }));
        });

        const resultado = [];
        buckets.forEach((bucket, idx) => {
          ordenarInsercionLigero(bucket);
          bucket.forEach((elemento) => {
            resultado.push(elemento);
            stats.iteraciones++;
            pasos.push(crearPaso(resultado.concat(items.slice(resultado.length)), stats, `Reinsertando bucket ${idx + 1}`, { resaltados: [resultado.length - 1] }));
          });
        });
        for (let i = 0; i < items.length; i++) {
          items[i] = resultado[i];
        }
        pasos.push(crearPaso(items, stats, "Buckets combinados"));
        return pasos;
      }

      function instrumentarRadix(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        const maxValor = Math.max(...items.map((item) => item.value), 1);
        const maxDigitos = Math.floor(Math.log10(maxValor)) + 1;
        let divisor = 1;

        for (let d = 0; d < maxDigitos; d++) {
          const buckets = Array.from({ length: 10 }, () => []);
          items.forEach((item) => {
            const digito = Math.floor((item.value / divisor) % 10);
            buckets[digito].push(clonarPunto(item));
            stats.iteraciones++;
          });
          pasos.push(crearPaso(items, stats, `Distribuyendo por dígito ${d + 1}`, { vista: "tree", tree: construirTreeRadix(buckets, d + 1) }));
          let idx = 0;
          buckets.forEach((bucket) => {
            bucket.forEach((elemento) => {
              items[idx++] = elemento;
            });
          });
          divisor *= 10;
          pasos.push(crearPaso(items, stats, `Reconstrucción tras dígito ${d + 1}`));
        }
        if (!pasos.length) pasos.push(crearPaso(items, stats, "Sin cambios"));
        return pasos;
      }

      function instrumentarCounting(datos) {
        const items = datos.map(clonarPunto);
        const stats = crearEstadisticas();
        const pasos = [];
        const maxValor = Math.max(...items.map((item) => item.value), 1);
        const contador = new Array(maxValor + 1).fill(0);

        items.forEach((item) => {
          contador[item.value]++;
          stats.iteraciones++;
          pasos.push(crearPaso(items, stats, `Contando ${item.label}`, { vista: "tree", tree: construirTreeContador(contador) }));
        });

        for (let i = 1; i < contador.length; i++) {
          contador[i] += contador[i - 1];
          stats.iteraciones++;
          pasos.push(crearPaso(items, stats, `Acumulando rango ${i}`, { vista: "tree", tree: construirTreeContador(contador) }));
        }

        const salida = new Array(items.length);
        for (let i = items.length - 1; i >= 0; i--) {
          const valor = items[i].value;
          contador[valor]--;
          const posicion = contador[valor];
          salida[posicion] = clonarPunto(items[i]);
          stats.intercambios++;
          pasos.push(crearPaso(salida.filter(Boolean), stats, `Colocando ${items[i].label}`));
        }

        for (let i = 0; i < items.length; i++) {
          items[i] = salida[i];
        }
        pasos.push(crearPaso(items, stats, "Reconstrucción completada"));
        return pasos;
      }

      const iniciarSimulacion = () => {
        prepararSimulacion();
        state.jugando = true;
        setStatus("Ejecutando");
        scheduleTick();
      };

      const resetVista = () => {
        detenerAnimacion();
        state.resultados = [];
        state.pasoActual = 0;
        state.maxPasos = 0;
        setStatus("En espera");
        updateUi();
        logArea.innerHTML = '<p>El registro mostrará el evento más reciente de la animación.</p>';
        configEstado.textContent = 'Configura y presiona "Simular" para generar los datos.';
      };

      sliderCantidad.addEventListener("input", (event) => {
