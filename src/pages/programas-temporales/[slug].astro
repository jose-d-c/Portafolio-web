      }

      function updateRangeLabels() {
        if (sizeLabel && sizeSlider instanceof HTMLInputElement) {
          sizeLabel.textContent = sizeSlider.value;
        }
        if (speedLabel && speedSlider instanceof HTMLInputElement) {
          const labels = ["", "muy lento", "lento", "moderado", "normal", "normal", "rápido", "rápido", "muy rápido", "ultra", "instante"];
          const idx = Number(speedSlider.value) || 0;
