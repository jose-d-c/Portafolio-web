        quick: { int: "/programas-temporales/programa-07", string: "/programas-temporales/programa-08" },
        heap: { int: "/programas-temporales/programa-24", string: "/programas-temporales/programa-25" },
        bucket: { int: "/programas-temporales/programa-26", string: "/programas-temporales/programa-27" },
        radix: { int: "/programas-temporales/programa-20" },
        counting: { int: "/programas-temporales/programa-29" }
      };

      const state = {
        tipoDato: "int",
        escenario: "desordenado",
        cantidad: Number(sliderCantidad.value),
        algoritmoActivo: "bubble",
        velocidad: Number(velocidadSelect.value),
        resultados: [],
        pasoActual: 0,
        maxPasos: 0,
        jugando: false,
        temporizador: null
      };

      const seleccionarBoton = (coleccion, boton) => {
        coleccion.forEach((item) => item.classList.remove("activo"));
        boton.classList.add("activo");
      };

      const setStatus = (texto) => {
        estadoTag.textContent = texto;
      };

      const obtenerColorBarra = (item, colorBase) => {
        if (state.tipoDato === "string") {
          const clave = item.label.charCodeAt(0);
          if (!colorCache.has(clave)) {
            const tono = stringPalette[colorCache.size % stringPalette.length];
            colorCache.set(clave, tono);
          }
          return colorCache.get(clave);
        }
        return colorBase;
      };

      const actualizarSliderLabel = () => {
        sliderValor.textContent = `${state.cantidad} datos`;
      };

      const actualizarEtiquetaEscenario = () => {
        etiquetaEscenario.textContent = `${ESCENARIOS[state.escenario].titulo} · ${tipoEtiqueta[state.tipoDato]}`;
      };

      const detenerAnimacion = () => {
        state.jugando = false;
        if (state.temporizador) {
          clearTimeout(state.temporizador);
          state.temporizador = null;
        }
      };

      const updateTimeline = () => {
        const total = Math.max(1, state.maxPasos - 1);
        const avance = state.resultados.length ? Math.min(1, state.pasoActual / total) : 0;
        timelineThumb.style.setProperty("--avance", `${avance * 100}%`);
      };

      const renderLog = (descripcionPaso, pasoActual, totalPasos) => {
        const mensaje = descripcionPaso ?? "Sin cambios visibles en este paso.";
        logArea.innerHTML = `<p><strong>Paso ${Math.min(pasoActual + 1, totalPasos)}</strong> · ${mensaje}</p>`;
      };

      const renderTreeView = (tree) => {
        visualStage.dataset.view = "tree";
        visualStage.innerHTML = "";
        const wrapper = document.createElement("div");
        wrapper.className = "sim-tree";
        const niveles = tree?.niveles ?? [];
        if (!niveles.length) {
          const texto = document.createElement("p");
          texto.className = "sim-placeholder";
          texto.textContent = "Estructura sin datos disponibles.";
          wrapper.appendChild(texto);
        } else {
          niveles.forEach((nivel) => {
            const fila = document.createElement("div");
            fila.className = "tree-level";
            nivel.forEach((nodo) => {
              const elemento = document.createElement("div");
              elemento.className = "tree-node";
              if (nodo.highlight) elemento.classList.add("activo");
              elemento.textContent = nodo.label;
              fila.appendChild(elemento);
            });
            wrapper.appendChild(fila);
          });
        }
        visualStage.appendChild(wrapper);
      };

      const renderBarsView = (paso, algoritmo) => {
        visualStage.dataset.view = "bars";
        visualStage.innerHTML = "";
        if (!paso.items?.length) {
          visualStage.innerHTML = '<p class="sim-placeholder">Inicia la simulación para ver las barras en movimiento.</p>';
          return;
        }
        const fragment = document.createDocumentFragment();
        const maxValor = Math.max(...paso.items.map((item) => item.value), 1);
        const mostrarEtiquetas = paso.items.length <= 45;
        paso.items.forEach((item, indice) => {
          const barra = document.createElement("div");
          barra.className = "sim-bar";
          barra.style.setProperty("--altura", `${Math.max(8, (item.value / maxValor) * 100)}%`);
          barra.style.setProperty("--bar-color", obtenerColorBarra(item, algoritmo.color));
          if (paso.resaltados?.includes(indice)) barra.classList.add("activo");
          if (mostrarEtiquetas) {
            barra.innerHTML = `<span>${item.label}</span>`;
          }
          fragment.appendChild(barra);
        });
        visualStage.appendChild(fragment);
      };

      const renderDescripcion = () => {
        const meta = ALGORITMOS[state.algoritmoActivo];
        if (!meta) return;
        descripcion.textContent = `${meta.descripcion} · Vista: ${meta.visual ?? "Barras"}`;
        estabilidad.textContent = meta.estable ? "Estable (mantiene el orden de iguales)" : "Inestable (puede reordenar valores identicos)";
        recursionTexto.textContent = meta.usaRecursion ? "Usa recursividad" : "Iterativo";
        situacionTexto.textContent = `${ESCENARIOS[state.escenario].titulo} · ${tipoEtiqueta[state.tipoDato]}`;
        if (linkPrograma) {
          const enlace = enlacesProgramas[state.algoritmoActivo]?.[state.tipoDato];
          if (enlace) {
            linkPrograma.href = enlace;
            linkPrograma.textContent = "Ver programa individual";
