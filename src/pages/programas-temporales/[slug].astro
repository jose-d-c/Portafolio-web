---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import { join } from "node:path";
import { programasTemporales } from "../../programas-temporales/programas";
import { metricasProgramas } from "../../programas-temporales/metricas";

export function getStaticPaths() {
  return programasTemporales.map((programa) => ({
    params: { slug: programa.slug },
    props: { programa },
  }));
}

const { programa } = Astro.props;
const codigoPlantilla = await readFile(
  join(process.cwd(), "public", programa.rutaCodigoPlantilla.replace(/^\//, "")),
  "utf-8"
);

const esComparativaMergeVsQuick = programa.slug === "programa-23";
const esSimuladorOrdenamientos = programa.slug === "programa-30";
const metricasPrograma = metricasProgramas[programa.slug];
const escenariosOrdenados: ["desordenado", "parcial", "intercalado", "invertido"] = [
  "desordenado",
  "parcial",
  "intercalado",
  "invertido",
];
const tamanosOrdenados: ["10", "100", "1000"] = ["10", "100", "1000"];
const tipoDatoLabels: Record<string, string> = {
  int: "números enteros",
  string: "cadenas de texto",
  binario: "colecciones ordenadas para búsqueda",
  mixto: "datos mixtos",
};

---

<BaseLayout title={`${programa.titulo} | Programas temporales`}>
  <main class="programa-shell">
    <section class="program-hero">
      <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
      <div>
        <p class="ds-eyebrow">Estructura de Datos y Analisis Algoritmicos</p>
        <h1>{programa.titulo}</h1>
        <p>{programa.descripcion}</p>
      </div>
      <a class="icono-volver" href="/" aria-label="Volver al menu principal" title="Volver al menu principal">
        <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
      </a>
    </section>

    {metricasPrograma && !esSimuladorOrdenamientos && (
      <section class="ds-card-grid info-programa">
        <article class="ds-card">
          <p class="ds-eyebrow">Autor del laboratorio</p>
          <h2>Jose David Consuegra Medina</h2>
          <p class="identidad-codigo">Código 2250167</p>
          <p>
            Cada ejecución cubre escenarios totalmente desordenados, parcialmente ordenados, intercalados e invertidos con 10, 100 y 1000 datos de tipo {tipoDatoLabels[metricasPrograma.tipoDato] ?? "base"}.
          </p>
        </article>
        <article class="ds-card">
          <h3>Ver simulador general</h3>
          <p>Explora el laboratorio visual con métricas en tiempo real para comparar algoritmos adicionales.</p>
          <a class="ds-button" href="/programas-temporales/programa-30">Abrir simulador</a>
        </article>
      </section>
    )}

    {metricasPrograma && !esSimuladorOrdenamientos && (
      <section class="ds-card-grid" aria-live="polite">
        {escenariosOrdenados.map((escenario) => {
          const datosEscenario = metricasPrograma.escenarios[escenario];
          if (!datosEscenario) return null;
          return (
            <article class="ds-card" data-escenario={escenario}>
              <header>
                <h3>{datosEscenario["10"].escenarioLabel}</h3>
                <p>Entradas: {datosEscenario["10"].entrada.replace(/\(10 elementos\)/, "(10, 100 y 1000)")}</p>
              </header>
              <div class="tabla-contenedor">
                <table class="tabla-comparativa">
                  <thead>
                    <tr>
                      <th>Datos</th>
                      <th>Tiempo (ms)</th>
                      <th>Memoria (KB)</th>
                      <th>Iteraciones</th>
                      <th>Comparaciones</th>
                      <th>Intercambios</th>
                    </tr>
                  </thead>
                  <tbody>
                    {tamanosOrdenados.map((tamano) => {
                      const registro = datosEscenario[tamano];
                      return (
                        <tr>
                          <td>{tamano}</td>
                          <td>{registro.tiempoMs}</td>
                          <td>{registro.memoriaKb}</td>
                          <td>{registro.iteraciones}</td>
                          <td>{registro.comparaciones}</td>
                          <td>{registro.intercambios}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
              <footer>
                <p>Ejemplo de salida: <strong>{datosEscenario["10"].salida}</strong></p>
              </footer>
            </article>
          );
        })}
      </section>
    )}

    {!esSimuladorOrdenamientos && (
      <section class="ds-panel zona-codigo">
        <div class="encabezado-cuadro">
          <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Código del programa</h2>
          <button class="boton-copiar" type="button" aria-label="Copiar codigo">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M8 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2V7Zm2 0h9v11h-9V7Z" />
              <path d="M5 4a2 2 0 0 1 2-2h9v2H7v11H5V4Zm-2 5h2v11a2 2 0 0 0 2 2h11v2H7a2 2 0 0 1-2-2V9Z" />
            </svg>
          </button>
        </div>

        <pre class="cuadro-codigo"><code>{codigoPlantilla}</code></pre>
      </section>
    )}

    {esComparativaMergeVsQuick && (
      <section class="panel subpanel zona-comparativa">
        <h2><img src="/icons/network.svg" alt="" class="ui-icon" aria-hidden="true" />Comparativa interactiva: Merge Sort vs Quick Sort</h2>
        <p class="texto-suave">
          Haz clic en una cuadricula para abrir el algoritmo correspondiente y despues explora las metricas por tamano de arreglo,
          tipo de dato y escenario de entrada.
        </p>

        <div class="grilla-accesos">
          <a class="acceso-algoritmo merge" href="/programas-temporales/programa-21">
            <span class="etiqueta-algoritmo">Merge Sort (int)</span>
            <strong>Ir a implementacion</strong>
            <small>Programa temporal 21</small>
          </a>
          <a class="acceso-algoritmo quick" href="/programas-temporales/programa-07">
            <span class="etiqueta-algoritmo">Quick Sort (int)</span>
            <strong>Ir a implementacion</strong>
            <small>Actividad 07</small>
          </a>
        </div>

        <div class="controles-comparativa">
          <label>
            Longitud
            <select id="filtro-longitud">
              <option value="10">10 elementos</option>
              <option value="50">50 elementos</option>
              <option value="200">200 elementos</option>
            </select>
          </label>
          <label>
            Tipo de arreglo
            <select id="filtro-tipo">
              <option value="int">int</option>
              <option value="string">string</option>
            </select>
          </label>
          <label>
            Situacion
            <select id="filtro-escenario">
              <option value="desordenado">Desordenado</option>
              <option value="parcial">Parcialmente desordenado</option>
              <option value="invertido">Invertido</option>
            </select>
          </label>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla-comparativa" id="tabla-comparativa">
            <thead>
              <tr>
                <th>Metrica</th>
                <th>Merge Sort</th>
                <th>Quick Sort</th>
                <th>Ventaja</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla-comparativa" id="tabla-complejidad">
            <thead>
              <tr>
                <th>Analisis</th>
                <th>Merge Sort</th>
                <th>Quick Sort</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>

        <div class="paneles-analisis">
          <article class="panel-analisis">
            <h3>Ventajas destacadas</h3>
            <ul id="lista-ventajas"></ul>
          </article>
          <article class="panel-analisis">
            <h3>Desventajas / alertas</h3>
            <ul id="lista-desventajas"></ul>
          </article>
          <article class="panel-analisis">
            <h3>Recomendacion automatica</h3>
            <p id="texto-recomendacion"></p>
          </article>
        </div>

        <section class="panel-definiciones">
          <div class="selector-definicion" role="tablist" aria-label="Definiciones detalladas">
            <button type="button" class="tab-definicion activo" data-algoritmo="merge">Merge Sort</button>
            <button type="button" class="tab-definicion" data-algoritmo="quick">Quick Sort</button>
          </div>
          <article class="detalle-algoritmo" id="detalle-algoritmo"></article>
        </section>
      </section>

      <section class="panel subpanel simulator-lab" aria-labelledby="simulador-heading">
        <div class="viz-head">
          <div>
            <p class="section-tag">visualización en vivo</p>
            <h2 id="simulador-heading">Simulador interactivo de algoritmos de ordenamiento</h2>
            <p>Explora cómo se comportan los algoritmos con arreglos configurables. Ajusta tamaño, velocidad y distribución inicial para observar comparaciones, intercambios y tiempos aproximados.</p>
          </div>
          <button class="contact-btn contact-mail viz-reset" type="button" id="simReset">Reiniciar</button>
        </div>

        <div class="viz-tabs" id="simTabs" role="tablist" aria-label="Algoritmos disponibles"></div>

        <div class="viz-controls">
          <label class="viz-ctrl">
            <span>Cantidad de elementos</span>
            <input type="range" id="simSize" min="8" max="80" value="30" step="1" />
            <strong id="simSizeVal">30</strong>
          </label>
          <label class="viz-ctrl">
            <span>Velocidad de animación</span>
            <input type="range" id="simSpeed" min="1" max="10" value="5" step="1" />
            <strong id="simSpeedVal">5 — normal</strong>
          </label>
          <label class="viz-ctrl">
            <span>Orden inicial</span>
            <select id="simOrder">
              <option value="random">Aleatorio</option>
              <option value="sorted">Ya ordenado</option>
              <option value="reverse">Invertido</option>
              <option value="nearlySorted">Casi ordenado</option>
              <option value="fewUnique">Pocos valores únicos</option>
              <option value="mountain">Montaña</option>
              <option value="valley">Valle</option>
              <option value="pipes">Zigzag</option>
            </select>
          </label>
          <label class="viz-ctrl">
            <span>Rango máximo</span>
            <input type="range" id="simRange" min="10" max="500" value="100" step="10" />
            <strong id="simRangeVal">1 – 100</strong>
          </label>
        </div>

        <div class="viz-actions">
          <button type="button" id="simGenerate">Generar arreglo</button>
          <button type="button" id="simStart">Iniciar</button>
          <button type="button" id="simPause" disabled>Pausar</button>
          <button type="button" id="simStep" disabled>Paso a paso</button>
        </div>

        <div class="viz-progress" aria-live="polite">
          <div class="viz-progress__fill" id="simProgress"></div>
        </div>

        <div class="viz-canvas">
          <canvas id="simCanvas" height="220" aria-label="Visualización de barras ordenadas"></canvas>
          <div class="viz-legend">
            <span><span class="viz-dot viz-dot--idle"></span>Sin tocar</span>
            <span><span class="viz-dot viz-dot--compare"></span>Comparando</span>
            <span><span class="viz-dot viz-dot--swap"></span>Intercambiando</span>
            <span><span class="viz-dot viz-dot--sorted"></span>Ordenado</span>
            <span><span class="viz-dot viz-dot--pivot"></span>Pivote</span>
            <span><span class="viz-dot viz-dot--min"></span>Mínimo</span>
          </div>
        </div>

        <div class="viz-stats">
          <article>
            <p>Comparaciones</p>
            <strong id="simComp">0</strong>
          </article>
          <article>
            <p>Intercambios</p>
            <strong id="simSwap">0</strong>
          </article>
          <article>
            <p>Tiempo (ms)</p>
            <strong id="simTime">0</strong>
          </article>
          <article>
            <p>Estado</p>
            <strong id="simState">listo</strong>
          </article>
        </div>

        <div class="viz-log" id="simLog" aria-live="polite">Selecciona un algoritmo y pulsa "Iniciar".</div>

        <div class="viz-info">
          <div>
            <h3 id="simInfoTitle">Bubble Sort</h3>
            <p id="simInfoDesc"></p>
          </div>
          <div class="viz-tags" id="simInfoComplexity"></div>
        </div>
      </section>
    )}

    {esSimuladorOrdenamientos && (
      <section class="ds-panel simulador-panel" data-simulador>
        <div class="sim-head">
          <div>
            <h2><img src="/icons/network.svg" alt="" class="ui-icon" aria-hidden="true" />Simulador visual de ordenamientos</h2>
            <p>
              Configura el tamaño, tipo de dato y situación del arreglo para comparar métricas clave de cada algoritmo mientras observas
              una animación en vivo del que selecciones. Cada pasada sincroniza la tabla comparativa con la ejecución actual.
            </p>
          </div>
          <div class="sim-head-badges">
            <span class="sim-badge">Tiempo real</span>
            <span class="sim-badge">Métricas completas</span>
            <span class="sim-badge">Datos dinamicos</span>
          </div>
        </div>

        <div class="sim-grid">
          <section class="sim-config" aria-labelledby="sim-config-titulo">
            <h3 id="sim-config-titulo">Panel de configuración</h3>
            <label class="sim-slider" for="sim-cantidad">
              <span>Datos a ordenar</span>
              <output id="sim-cantidad-valor" for="sim-cantidad">32 datos</output>
              <input id="sim-cantidad" type="range" min="8" max="60" step="2" value="32" />
            </label>

            <div class="sim-group">
              <p class="sim-group-title">Tipo de dato</p>
              <div class="sim-pill-group" role="group" aria-label="Tipo de dato">
                <button type="button" class="sim-pill activo" data-tipo="int">Enteros</button>
                <button type="button" class="sim-pill" data-tipo="string">Strings</button>
              </div>
            </div>

            <div class="sim-group">
              <p class="sim-group-title">Situación del arreglo</p>
              <div class="sim-scenarios" role="group" aria-label="Situación del arreglo">
                <button type="button" class="sim-scenario activo" data-escenario="desordenado">
                  <strong>Totalmente desordenado</strong>
                  <small>Nuevo shuffle en cada ejecución</small>
                </button>
                <button type="button" class="sim-scenario" data-escenario="parcial">
                  <strong>Parcialmente ordenado</strong>
                  <small>Subbloques ordenados y swaps puntuales</small>
                </button>
                <button type="button" class="sim-scenario" data-escenario="intercalado">
                  <strong>Intercalado</strong>
                  <small>Oscila entre valores altos y bajos</small>
                </button>
                <button type="button" class="sim-scenario" data-escenario="invertido">
                  <strong>Invertido</strong>
                  <small>Mayor a menor estricto</small>
                </button>
              </div>
            </div>

            <div class="sim-group">
              <p class="sim-group-title">Algoritmo a visualizar</p>
              <div class="sim-pill-group" role="tablist" aria-label="Algoritmos disponibles" id="sim-algoritmos">
                <button type="button" class="sim-pill activo" data-algoritmo="bubble" data-programa="/programas-temporales/programa-01">Bubble</button>
                <button type="button" class="sim-pill" data-algoritmo="bubblePlus" data-programa="/programas-temporales/programa-05">Bubble+</button>
                <button type="button" class="sim-pill" data-algoritmo="selection" data-programa="/programas-temporales/programa-11">Selection</button>
                <button type="button" class="sim-pill" data-algoritmo="insertion" data-programa="/programas-temporales/programa-15">Insertion</button>
                <button type="button" class="sim-pill" data-algoritmo="shell" data-programa="/programas-temporales/programa-09">Shell</button>
                <button type="button" class="sim-pill" data-algoritmo="shaker" data-programa="/programas-temporales/programa-18">Shaker</button>
                <button type="button" class="sim-pill" data-algoritmo="merge" data-programa="/programas-temporales/programa-21">Merge</button>
                <button type="button" class="sim-pill" data-algoritmo="quick" data-programa="/programas-temporales/programa-07">Quick</button>
                <button type="button" class="sim-pill" data-algoritmo="heap" data-programa="/programas-temporales/programa-24">Heap</button>
                <button type="button" class="sim-pill" data-algoritmo="bucket" data-programa="/programas-temporales/programa-26">Bucket</button>
                <button type="button" class="sim-pill" data-algoritmo="radix" data-programa="/programas-temporales/programa-20">Radix</button>
                <button type="button" class="sim-pill" data-algoritmo="counting" data-programa="/programas-temporales/programa-29">Counting</button>
              </div>
            </div>
            <a class="sim-program-link" id="sim-program-link" href="/programas-temporales/programa-01" target="_blank" rel="noreferrer">Ver programa individual</a>

            <div class="sim-controls">
              <label class="sim-select">
                <span>Velocidad de animacion</span>
                <select id="sim-velocidad">
                  <option value="750">Calmada</option>
                  <option value="420" selected>Dinámica</option>
                  <option value="200">Rápida</option>
                </select>
              </label>
              <div class="sim-actions">
                <button type="button" class="sim-btn primario" id="sim-start">Simular</button>
                <button type="button" class="sim-btn" id="sim-pause">Pausar</button>
                <button type="button" class="sim-btn fantasma" id="sim-reset">Reiniciar</button>
              </div>
            </div>

            <p class="sim-config-note" id="sim-config-estado">Configura y presiona "Simular" para generar los datos.</p>
          </section>

          <section class="sim-table" aria-live="polite">
            <div class="sim-table-head">
              <h3>Tabla comparativa paso a paso</h3>
              <span class="sim-tag" id="sim-etiqueta-escenario">Desordenado · Enteros</span>
            </div>
            <div class="tabla-contenedor">
                <table class="tabla-comparativa" id="sim-tabla">
                  <thead>
                    <tr>
                      <th>Algoritmo</th>
                      <th>Paso</th>
                      <th>Comparaciones</th>
                      <th>Intercambios</th>
                      <th>Iteraciones</th>
                      <th>Tiempo (ms)</th>
                      <th>Memoria (KB)</th>
                      <th>Recursivo</th>
                      <th>Estable</th>
                      <th>Programa</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td colspan="10">Aún no hay datos procesados.</td>
                    </tr>
                  </tbody>
                </table>
            </div>
            <div class="sim-legend">
              <p>Las barras usan colores proporcionales al valor; para strings cada letra recibe un color dedicado y las barras resaltadas indican comparaciones activas. Cuando un algoritmo requiere estructuras auxiliares se muestra un grafo animado.</p>
            </div>
          </section>

          <section class="sim-visual">
            <div class="sim-visual-head">
              <h3>Animacion del algoritmo</h3>
              <span class="sim-tag" id="sim-estado">En espera</span>
            </div>
            <div class="sim-visual-stage" id="sim-visual">
              <p class="sim-placeholder">Inicia la simulación para ver las barras en movimiento.</p>
            </div>
            <div class="sim-timeline">
              <div class="sim-timeline-track">
                <div class="sim-timeline-thumb" id="sim-timeline"></div>
              </div>
            </div>
          </section>

          <section class="sim-descripcion">
            <h3>Ficha descriptiva</h3>
            <dl>
              <div>
                <dt>Descripcion</dt>
                <dd id="sim-descripcion">Selecciona un algoritmo para revisar su logica y estabilidad.</dd>
              </div>
              <div>
                <dt>Estabilidad</dt>
                <dd id="sim-estabilidad">—</dd>
              </div>
              <div>
                <dt>Recursividad</dt>
                <dd id="sim-recursion">—</dd>
              </div>
              <div>
                <dt>Situacion actual</dt>
                <dd id="sim-situacion">—</dd>
              </div>
            </dl>
            <div class="sim-log" id="sim-log">
              <p>El registro mostrará el evento más reciente de la animación.</p>
            </div>
          </section>
        </div>
      </section>
    )}

    <section class="panel subpanel zona-imagen">
      <h2><img src="/icons/flask.svg" alt="" class="ui-icon" aria-hidden="true" />Imagen de salida</h2>

      <div class="marco-imagen">
        <img
          id="imagen-salida-programa"
          src={programa.rutaImagenPlantilla}
          alt={`Imagen de salida de ${programa.titulo}`}
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>
  </main>

  <script is:inline>
    (function setupClipboard() {
      const trigger = document.querySelector(".boton-copiar");
      const codigo = document.querySelector(".cuadro-codigo");
      if (!trigger || !codigo) return;

      trigger.addEventListener("click", async () => {
        const texto = codigo.textContent ?? "";
        try {
          await navigator.clipboard.writeText(texto);
          trigger.innerHTML = "✅";
          setTimeout(() => {
            trigger.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2V7Zm2 0h9v11h-9V7Z" /><path d="M5 4a2 2 0 0 1 2-2h9v2H7v11H5V4Zm-2 5h2v11a2 2 0 0 0 2 2h11v2H7a2 2 0 0 1-2-2V9Z" /></svg>`;
          }, 1400);
        } catch {
          const seleccion = window.getSelection();
          const rango = document.createRange();
          rango.selectNodeContents(codigo);
          seleccion?.removeAllRanges();
          seleccion?.addRange(rango);
        }
      });
    })();

    (function setupComparativa() {
      const tabla = document.querySelector("#tabla-comparativa");
      if (!tabla) return;

      const datosComparativa = {
        int: {
          desordenado: {
            10: { merge: { tiempo: 0.07, comparaciones: 28, movimientos: 40, memoria: 6 }, quick: { tiempo: 0.05, comparaciones: 24, movimientos: 19, memoria: 2 } },
            50: { merge: { tiempo: 0.45, comparaciones: 276, movimientos: 438, memoria: 24 }, quick: { tiempo: 0.36, comparaciones: 251, movimientos: 184, memoria: 7 } },
            200: { merge: { tiempo: 2.21, comparaciones: 1540, movimientos: 2874, memoria: 95 }, quick: { tiempo: 1.66, comparaciones: 1394, movimientos: 980, memoria: 13 } }
          },
          parcial: {
            10: { merge: { tiempo: 0.06, comparaciones: 24, movimientos: 40, memoria: 6 }, quick: { tiempo: 0.04, comparaciones: 18, movimientos: 14, memoria: 2 } },
            50: { merge: { tiempo: 0.41, comparaciones: 249, movimientos: 438, memoria: 24 }, quick: { tiempo: 0.29, comparaciones: 190, movimientos: 133, memoria: 6 } },
