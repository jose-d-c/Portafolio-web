      const definicionesDetalladas = {
        merge: {
          titulo: "Merge Sort",
          funcionalidad: [
            "Divide recursivamente el arreglo en mitades hasta tener subarreglos de un elemento.",
            "Conquista mezclando subarreglos ya ordenados mediante comparacion secuencial.",
            "Mantiene orden estable: elementos iguales conservan su posicion relativa."
          ],
          ventajas: [
            "Complejidad temporal estable O(n log n) en mejor, promedio y peor caso.",
            "Excelente comportamiento en entradas invertidas o con patron adverso.",
            "Muy util para listas enlazadas y para ordenamiento externo en disco."
          ],
          desventajas: [
            "Requiere memoria auxiliar O(n) para el proceso de mezcla.",
            "Puede ser menos rapido que Quick Sort en arreglos pequenos en memoria RAM.",
            "Coste adicional de copiado/movimientos durante cada fase de merge."
          ]
        },
        quick: {
          titulo: "Quick Sort",
          funcionalidad: [
            "Selecciona un pivote y particiona el arreglo en menores/mayores al pivote.",
