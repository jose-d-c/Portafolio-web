      const ALGOS = {
        bubble: { name: "Bubble", full: "Bubble Sort", desc: "Compara pares adyacentes y los intercambia si están en el orden incorrecto.", best: "O(n)", avg: "O(n²)", worst: "O(n²)", space: "O(1)", stable: true },
        selection: { name: "Selection", full: "Selection Sort", desc: "Busca el mínimo del subarreglo no ordenado y lo coloca al inicio.", best: "O(n²)", avg: "O(n²)", worst: "O(n²)", space: "O(1)", stable: false },
        insertion: { name: "Insertion", full: "Insertion Sort", desc: "Inserta cada elemento en la parte ya ordenada del arreglo.", best: "O(n)", avg: "O(n²)", worst: "O(n²)", space: "O(1)", stable: true },
        shell: { name: "Shell", full: "Shell Sort", desc: "Generalización de insertion con gaps decrecientes.", best: "O(n log n)", avg: "O(n^{1.3})", worst: "O(n²)", space: "O(1)", stable: false },
        merge: { name: "Merge", full: "Merge Sort", desc: "Divide y combina subarreglos con complejidad O(n log n).", best: "O(n log n)", avg: "O(n log n)", worst: "O(n log n)", space: "O(n)", stable: true },
        quick: { name: "Quick", full: "Quick Sort", desc: "Particiona usando un pivote y recurre sobre cada mitad.", best: "O(n log n)", avg: "O(n log n)", worst: "O(n²)", space: "O(log n)", stable: false },
        heap: { name: "Heap", full: "Heap Sort", desc: "Construye un max-heap y extrae el máximo sucesivamente.", best: "O(n log n)", avg: "O(n log n)", worst: "O(n log n)", space: "O(1)", stable: false },
        counting: { name: "Counting", full: "Counting Sort", desc: "Cuenta ocurrencias de cada valor dentro de un rango acotado.", best: "O(n+k)", avg: "O(n+k)", worst: "O(n+k)", space: "O(k)", stable: true },
        radix: { name: "Radix", full: "Radix Sort", desc: "Ordena dígito a dígito usando counting como subrutina.", best: "O(d·n)", avg: "O(d·n)", worst: "O(d·n)", space: "O(n+k)", stable: true },
        cocktail: { name: "Cocktail", full: "Cocktail Shaker Sort", desc: "Burbuja bidireccional que recorre en ambos sentidos.", best: "O(n)", avg: "O(n²)", worst: "O(n²)", space: "O(1)", stable: true },
        gnome: { name: "Gnome", full: "Gnome Sort", desc: "Variante de insertion que retrocede cuando encuentra desórdenes.", best: "O(n)", avg: "O(n²)", worst: "O(n²)", space: "O(1)", stable: true },
        cycle: { name: "Cycle", full: "Cycle Sort", desc: "Minimiza escrituras determinando la posición final de cada elemento.", best: "O(n²)", avg: "O(n²)", worst: "O(n²)", space: "O(1)", stable: false }
      };

      const ALGO_KEYS = Object.keys(ALGOS);
      let currentAlgo = ALGO_KEYS[0];
      let arr = [];
      let running = false;
      let paused = false;
      let comparisons = 0;
      let swaps = 0;
