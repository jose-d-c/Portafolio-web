        counting: { nombre: "Counting Sort", descripcion: "Cuenta apariciones y reconstruye el arreglo ordenado.", estable: true, usaRecursion: false, color: "#94a3b8", ejecutar: instrumentarCounting, visual: "Árbol de frecuencias" }
      };

      const enlacesProgramas = {
