        }
        if (rangeLabel && rangeSlider instanceof HTMLInputElement) {
          rangeLabel.textContent = `1 – ${rangeSlider.value}`;
        }
      }

      function makeArray() {
        const n = Number(sizeSlider?.value ?? 30);
        const max = Number(rangeSlider?.value ?? 100);
        const order = orderSelect?.value ?? "random";
        let base = Array.from({ length: n }, () => Math.floor(Math.random() * Math.max(1, max - 1)) + 1);
        const shuffle = () => base.sort(() => Math.random() - 0.5);
        switch (order) {
          case "sorted":
            base.sort((a, b) => a - b);
            break;
          case "reverse":
            base.sort((a, b) => b - a);
            break;
          case "nearlySorted":
            base.sort((a, b) => a - b);
            for (let i = 0; i < Math.max(1, Math.floor(n * 0.1)); i++) {
              const x = Math.floor(Math.random() * n);
              const y = Math.floor(Math.random() * n);
              [base[x], base[y]] = [base[y], base[x]];
            }
            break;
          case "fewUnique":
            const values = [Math.floor(max * 0.2), Math.floor(max * 0.5), Math.floor(max * 0.8)];
            base = base.map(() => values[Math.floor(Math.random() * values.length)]);
            break;
          case "mountain":
            base.sort((a, b) => a - b);
            base = [...base.slice(0, Math.floor(n / 2)), ...base.slice(Math.floor(n / 2)).reverse()];
            break;
          case "valley":
            base.sort((a, b) => b - a);
            base = [...base.slice(0, Math.floor(n / 2)), ...base.slice(Math.floor(n / 2)).reverse()];
            break;
          case "pipes":
            base.sort((a, b) => a - b);
            const temp = [];
            for (let i = 0; i < base.length; i += 2) temp.push(base[i]);
            for (let i = 1; i < base.length; i += 2) temp.unshift(base[i]);
            base = temp;
            break;
          default:
            shuffle();
            break;
        }
        return base;
      }

      function drawArray(values, hint = {}) {
        const dpr = window.devicePixelRatio || 1;
        const width = canvas.width / dpr;
        const height = canvas.height / dpr;
        ctx.clearRect(0, 0, width, height);
        if (!values.length) return;
        const max = Math.max(...values, 1);
        const gap = 2;
        const barWidth = Math.max(2, (width - gap * (values.length - 1)) / values.length);
        values.forEach((value, index) => {
          const barHeight = Math.max(4, (value / max) * (height - 18));
          const x = index * (barWidth + gap);
          const y = height - barHeight - 18;
          let color = "#378add";
          if (hint.sorted && hint.sorted.has(index)) color = "#1d9e75";
          else if (hint.pivot === index) color = "#7f77dd";
          else if (hint.min === index) color = "#d4537e";
          else if (hint.swap && hint.swap.includes(index)) color = "#d85a30";
          else if (hint.compare && hint.compare.includes(index)) color = "#ef9f27";
          ctx.fillStyle = color;
          ctx.fillRect(x, y, barWidth, barHeight);
        });
      }

      function resetStats() {
        comparisons = 0;
        swaps = 0;
        if (compEl) compEl.textContent = "0";
        if (swapEl) swapEl.textContent = "0";
        if (timeEl) timeEl.textContent = "0";
        if (stateEl) stateEl.textContent = "listo";
        if (progressFill) progressFill.style.width = "0%";
      }

      function log(message) {
        if (!logEl) return;
        logEl.innerHTML += `${message}<br />`;
        logEl.scrollTop = logEl.scrollHeight;
      }

      function setRunning(active) {
        running = active;
        if (startBtn) startBtn.toggleAttribute("disabled", active);
        if (generateBtn) generateBtn.toggleAttribute("disabled", active);
        if (pauseBtn) pauseBtn.toggleAttribute("disabled", !active);
        if (stepBtn) stepBtn.toggleAttribute("disabled", !active);
        if (sizeSlider) sizeSlider.toggleAttribute("disabled", active);
        if (orderSelect) orderSelect.toggleAttribute("disabled", active);
        if (rangeSlider) rangeSlider.toggleAttribute("disabled", active);
      }

      function getDelay() {
        const speeds = [0, 500, 250, 120, 60, 30, 15, 8, 3, 1, 0];
        const idx = Number(speedSlider?.value ?? 5);
        return speeds[idx] ?? 60;
      }

      async function startSort() {
        if (running) return;
        if (!arr.length) generateArray();
        resetStats();
        setRunning(true);
        paused = false;
        if (pauseBtn) pauseBtn.textContent = "Pausar";
        if (stateEl) stateEl.textContent = "ordenando";
        startTime = performance.now();
        log(`▶ Iniciando ${ALGOS[currentAlgo].full} con ${arr.length} elementos...`);
        const working = [...arr];
        const sortedSet = new Set();
        try {
          await SORT_FUNCS[currentAlgo](working, sortedSet);
        } catch (error) {
          if (error !== "stopped") throw error;
        }
        if (running) {
          working.forEach((_, idx) => sortedSet.add(idx));
          arr = [...working];
          drawArray(arr, { sorted: sortedSet });
          const elapsed = Math.round(performance.now() - startTime);
          if (timeEl) timeEl.textContent = String(elapsed);
          if (stateEl) stateEl.textContent = "completado";
          if (progressFill) progressFill.style.width = "100%";
          log(`✓ Completado en ${elapsed}ms | ${comparisons} comp. | ${swaps} intercambios`);
        }
        setRunning(false);
      }

      function togglePause() {
        if (!running) return;
        paused = !paused;
        if (pauseBtn) pauseBtn.textContent = paused ? "Continuar" : "Pausar";
        if (stateEl) stateEl.textContent = paused ? "pausado" : "ordenando";
      }

      function stepOnce() {
        paused = true;
        if (pauseBtn) pauseBtn.textContent = "Continuar";
      }

      function resetAll() {
        if (animToken) {
          clearTimeout(animToken);
          animToken = undefined;
        }
        running = false;
        paused = false;
        if (pauseBtn) {
          pauseBtn.textContent = "Pausar";
          pauseBtn.setAttribute("disabled", "true");
        }
        if (stepBtn) stepBtn.setAttribute("disabled", "true");
        setRunning(false);
        generateArray();
      }

      async function wait(hint, progress) {
        comparisons++;
        if (compEl) compEl.textContent = String(comparisons);
        if (progressFill && progress !== undefined) {
          progressFill.style.width = `${Math.min(100, Math.max(0, progress * 100))}%`;
        }
        drawArray(arr, hint);
        while (paused) {
          await new Promise((resolve) => setTimeout(resolve, 50));
          if (!running) throw "stopped";
        }
        if (!running) throw "stopped";
        const delay = getDelay();
        if (delay > 0) await new Promise((resolve) => setTimeout(resolve, delay));
      }

      async function doSwap(array, i, j, hint) {
        [array[i], array[j]] = [array[j], array[i]];
        arr[i] = array[i];
        arr[j] = array[j];
        swaps++;
        if (swapEl) swapEl.textContent = String(swaps);
        hint.swap = [i, j];
        drawArray(arr, hint);
        if (!running) throw "stopped";
        const delay = getDelay();
        if (delay > 0) await new Promise((resolve) => setTimeout(resolve, Math.floor(delay / 2)));
      }

      const SORT_FUNCS = {
        async bubble(a, sorted) {
          for (let i = 0; i < a.length - 1; i++) {
            let swapped = false;
            for (let j = 0; j < a.length - i - 1; j++) {
              await wait({ compare: [j, j + 1], sorted }, (i * a.length + j) / (a.length * a.length));
              if (a[j] > a[j + 1]) {
                await doSwap(a, j, j + 1, { sorted });
                swapped = true;
              }
            }
            sorted.add(a.length - 1 - i);
            if (!swapped) break;
          }
          sorted.add(0);
        },
        async selection(a, sorted) {
          for (let i = 0; i < a.length - 1; i++) {
            let minIdx = i;
            for (let j = i + 1; j < a.length; j++) {
              await wait({ compare: [minIdx, j], min: minIdx, sorted }, i / a.length);
              if (a[j] < a[minIdx]) minIdx = j;
            }
            if (minIdx !== i) await doSwap(a, i, minIdx, { sorted });
            sorted.add(i);
          }
          sorted.add(a.length - 1);
        },
        async insertion(a, sorted) {
          sorted.add(0);
          for (let i = 1; i < a.length; i++) {
            const key = a[i];
            let j = i - 1;
            while (j >= 0 && a[j] > key) {
              await wait({ compare: [j, j + 1], sorted }, i / a.length);
              a[j + 1] = a[j];
              arr[j + 1] = a[j];
              swaps++;
              if (swapEl) swapEl.textContent = String(swaps);
              j--;
            }
            a[j + 1] = key;
            arr[j + 1] = key;
            sorted.add(i);
          }
        },
        async shell(a, sorted) {
          let gap = 1;
          while (gap < Math.floor(a.length / 3)) gap = gap * 3 + 1;
          while (gap >= 1) {
            for (let i = gap; i < a.length; i++) {
              const temp = a[i];
              let j = i;
              while (j >= gap && a[j - gap] > temp) {
                await wait({ compare: [j - gap, j], sorted }, gap / a.length);
                a[j] = a[j - gap];
                arr[j] = a[j];
                swaps++;
                if (swapEl) swapEl.textContent = String(swaps);
                j -= gap;
              }
              a[j] = temp;
              arr[j] = temp;
            }
            gap = Math.floor(gap / 3);
          }
          a.forEach((_, idx) => sorted.add(idx));
        },
        async merge(a, sorted) {
          const temp = Array(a.length);
          async function mergeSort(left, right) {
            if (left >= right) return;
            const mid = Math.floor((left + right) / 2);
            await mergeSort(left, mid);
            await mergeSort(mid + 1, right);
            let i = left;
            let j = mid + 1;
            let k = left;
            while (i <= mid && j <= right) {
              await wait({ compare: [i, j], sorted }, (k - left) / (right - left + 1));
              if (a[i] <= a[j]) temp[k++] = a[i++];
              else temp[k++] = a[j++];
            }
            while (i <= mid) temp[k++] = a[i++];
            while (j <= right) temp[k++] = a[j++];
            for (let idx = left; idx <= right; idx++) {
              a[idx] = temp[idx];
              arr[idx] = temp[idx];
            }
          }
          await mergeSort(0, a.length - 1);
          a.forEach((_, idx) => sorted.add(idx));
        },
        async quick(a, sorted) {
          async function quickSort(start, end) {
            if (start >= end) return;
            const pivotIndex = await partition(start, end);
            sorted.add(pivotIndex);
            await quickSort(start, pivotIndex - 1);
            await quickSort(pivotIndex + 1, end);
          }
          async function partition(start, end) {
            const pivot = a[end];
            let i = start;
            for (let j = start; j < end; j++) {
              await wait({ compare: [j, end], pivot: end }, j / a.length);
              if (a[j] < pivot) {
                await doSwap(a, i, j, { pivot: end });
                i++;
              }
            }
            await doSwap(a, i, end, { pivot: i });
            return i;
          }
          await quickSort(0, a.length - 1);
          a.forEach((_, idx) => sorted.add(idx));
        },
        async heap(a, sorted) {
          const heapify = async (n, i) => {
            let largest = i;
            const left = 2 * i + 1;
            const right = 2 * i + 2;
            if (left < n && a[left] > a[largest]) largest = left;
            if (right < n && a[right] > a[largest]) largest = right;
            if (largest !== i) {
              await doSwap(a, i, largest, {});
              await heapify(n, largest);
            }
          };
          for (let i = Math.floor(a.length / 2) - 1; i >= 0; i--) {
            await heapify(a.length, i);
          }
          for (let end = a.length - 1; end > 0; end--) {
            await doSwap(a, 0, end, { sorted });
            sorted.add(end);
            await heapify(end, 0);
          }
          sorted.add(0);
        },
        async counting(a, sorted) {
          const max = Math.max(...a);
          const counts = new Array(max + 1).fill(0);
          a.forEach((val) => counts[val]++);
          for (let i = 1; i < counts.length; i++) counts[i] += counts[i - 1];
          const output = new Array(a.length);
          for (let i = a.length - 1; i >= 0; i--) {
            const val = a[i];
            counts[val]--;
            output[counts[val]] = val;
            swaps++;
            if (swapEl) swapEl.textContent = String(swaps);
            drawArray(output.filter(Boolean));
            await new Promise((resolve) => setTimeout(resolve, getDelay()));
          }
          for (let i = 0; i < output.length; i++) {
            a[i] = output[i];
            arr[i] = output[i];
            sorted.add(i);
          }
        },
        async radix(a, sorted) {
          const max = Math.max(...a);
          let exp = 1;
          while (Math.floor(max / exp) > 0) {
            const buckets = Array.from({ length: 10 }, () => []);
            for (const val of a) {
              buckets[Math.floor(val / exp) % 10].push(val);
            }
            let idx = 0;
            for (const bucket of buckets) {
              for (const val of bucket) {
                a[idx] = val;
                arr[idx] = val;
                idx++;
              }
            }
            exp *= 10;
            await wait({}, exp / max);
          }
          a.forEach((_, idx) => sorted.add(idx));
        },
        async cocktail(a, sorted) {
          let startIdx = 0;
          let endIdx = a.length - 1;
          while (startIdx < endIdx) {
            for (let i = startIdx; i < endIdx; i++) {
              await wait({ compare: [i, i + 1], sorted }, i / a.length);
              if (a[i] > a[i + 1]) await doSwap(a, i, i + 1, { sorted });
            }
            sorted.add(endIdx--);
            for (let i = endIdx; i > startIdx; i--) {
              await wait({ compare: [i - 1, i], sorted }, i / a.length);
              if (a[i - 1] > a[i]) await doSwap(a, i - 1, i, { sorted });
            }
            sorted.add(startIdx++);
          }
        },
        async gnome(a, sorted) {
          let idx = 0;
          while (idx < a.length) {
            if (idx === 0 || a[idx] >= a[idx - 1]) {
              idx++;
            } else {
              await doSwap(a, idx, idx - 1, {});
              idx--;
            }
            await wait({}, idx / a.length);
          }
          a.forEach((_, i) => sorted.add(i));
        },
        async cycle(a, sorted) {
          for (let cycleStart = 0; cycleStart < a.length - 1; cycleStart++) {
            let item = a[cycleStart];
            let pos = cycleStart;
            for (let i = cycleStart + 1; i < a.length; i++) {
              if (a[i] < item) pos++;
            }
            if (pos === cycleStart) continue;
            while (item === a[pos]) pos++;
            [a[pos], item] = [item, a[pos]];
            arr[pos] = a[pos];
            swaps++;
            if (swapEl) swapEl.textContent = String(swaps);
            await wait({}, pos / a.length);
            while (pos !== cycleStart) {
              pos = cycleStart;
              for (let i = cycleStart + 1; i < a.length; i++) {
                if (a[i] < item) pos++;
              }
              while (item === a[pos]) pos++;
              [a[pos], item] = [item, a[pos]];
              arr[pos] = a[pos];
              swaps++;
              if (swapEl) swapEl.textContent = String(swaps);
              await wait({}, pos / a.length);
            }
          }
          a.forEach((_, idx) => sorted.add(idx));
        }
      };

      function generateArray() {
        arr = makeArray();
        drawArray(arr);
        resetStats();
        log("Arreglo generado: " + arr.length + " elementos");
      }

      buildTabs();
      updateInfo();
      updateRangeLabels();
      generateArray();

      sizeSlider?.addEventListener("input", () => {
        updateRangeLabels();
        if (!running) {
          generateArray();
        }
      });
      speedSlider?.addEventListener("input", updateRangeLabels);
      rangeSlider?.addEventListener("input", () => {
        updateRangeLabels();
        if (!running) generateArray();
      });
      orderSelect?.addEventListener("change", () => {
        if (!running) generateArray();
      });
      generateBtn?.addEventListener("click", () => {
        if (!running) generateArray();
      });
      startBtn?.addEventListener("click", startSort);
      pauseBtn?.addEventListener("click", togglePause);
      stepBtn?.addEventListener("click", stepOnce);
      resetBtn?.addEventListener("click", resetAll);
    })();
  </script>

</BaseLayout>
