      const ESCENARIOS = {
        desordenado: { titulo: "Totalmente desordenado", descripcion: "Cada corrida baraja los datos para ejercitar el peor recorrido promedio." },
        parcial: { titulo: "Parcialmente ordenado", descripcion: "Bloques ordenados con swaps controlados para medir optimizaciones." },
        intercalado: { titulo: "Intercalado", descripcion: "Valores altos y bajos alternan, desafiando comparaciones locales." },
        invertido: { titulo: "Invertido", descripcion: "Orden inverso absoluto para evidenciar el peor caso." }
      };

      const tipoEtiqueta = { int: "Enteros", string: "Strings" };
      const stringPalette = ["#f472b6", "#fb7185", "#facc15", "#34d399", "#22d3ee", "#60a5fa", "#a78bfa", "#fbbf24", "#4ade80", "#f87171"];
      const colorCache = new Map();

      const ALGORITMOS = {
        bubble: { nombre: "Bubble Sort", descripcion: "Versión clásica que compara vecinos y empuja el mayor al final.", estable: true, usaRecursion: false, color: "#8b5cf6", ejecutar: instrumentarBurbuja, visual: "Barras dinámicas" },
        bubblePlus: { nombre: "Bubble Sort optimizado", descripcion: "Reduce pasadas al recordar el ultimo intercambio.", estable: true, usaRecursion: false, color: "#a855f7", ejecutar: instrumentarBurbujaPlus, visual: "Barras con cortes anticipados" },
        selection: { nombre: "Selection Sort", descripcion: "Encuentra el minimo restante y lo coloca en su sitio.", estable: false, usaRecursion: false, color: "#f97316", ejecutar: instrumentarSeleccion, visual: "Barras" },
        insertion: { nombre: "Insertion Sort", descripcion: "Inserta cada elemento en la zona ordenada desplazándolo.", estable: true, usaRecursion: false, color: "#10b981", ejecutar: instrumentarInsercion, visual: "Barras" },
        shell: { nombre: "Shell Sort", descripcion: "Ordena usando gaps decrecientes para acelerar Inserción.", estable: false, usaRecursion: false, color: "#06b6d4", ejecutar: instrumentarShell, visual: "Barras" },
        shaker: { nombre: "Shaker Sort", descripcion: "Burbuja bidireccional que recorre ida y vuelta.", estable: true, usaRecursion: false, color: "#f59e0b", ejecutar: instrumentarShaker, visual: "Barras" },
        merge: { nombre: "Merge Sort", descripcion: "Divide y conquista mezclando subarreglos ordenados.", estable: true, usaRecursion: true, color: "#0ea5e9", ejecutar: instrumentarMerge, visual: "Barras + árbol de fusiones" },
        quick: { nombre: "Quick Sort", descripcion: "Particiona alrededor de pivotes y resuelve recursivamente.", estable: false, usaRecursion: true, color: "#ec4899", ejecutar: instrumentarQuick, visual: "Barras" },
        heap: { nombre: "Heap Sort", descripcion: "Construye un montículo y extrae máximos.", estable: false, usaRecursion: false, color: "#facc15", ejecutar: instrumentarHeap, visual: "Árbol binario" },
        bucket: { nombre: "Bucket Sort", descripcion: "Distribuye elementos en cubetas y las ordena por separado.", estable: true, usaRecursion: false, color: "#2dd4bf", ejecutar: instrumentarBucket, visual: "Árbol de buckets" },
