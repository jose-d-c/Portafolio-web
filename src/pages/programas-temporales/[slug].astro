---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import { join } from "node:path";
import { programasTemporales } from "../../programas-temporales/programas";

export function getStaticPaths() {
  return programasTemporales.map((programa) => ({
    params: { slug: programa.slug },
    props: { programa },
  }));
}

const { programa } = Astro.props;
const codigoPlantilla = await readFile(
  join(process.cwd(), "public", programa.rutaCodigoPlantilla.replace(/^\//, "")),
  "utf-8"
);

const esComparativaMergeVsQuick = programa.slug === "programa-23";

---

<BaseLayout title={`${programa.titulo} | Programas temporales`}>
  <main class="app-shell programa-shell">
    <section class="panel encabezado-programa">
      <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
      <div>
        <p class="eyebrow">Estructura de Datos y Analisis Algoritmicos</p>
        <h1>{programa.titulo}</h1>
        <p>{programa.descripcion}</p>
      </div>
      <a class="icono-volver" href="/" aria-label="Volver al menu principal" title="Volver al menu principal">
        <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
      </a>
    </section>

    <section class="panel subpanel zona-codigo">
      <div class="encabezado-cuadro">
        <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Codigo del programa</h2>
        <button class="boton-copiar" type="button" aria-label="Copiar codigo">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M8 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2V7Zm2 0h9v11h-9V7Z" />
            <path d="M5 4a2 2 0 0 1 2-2h9v2H7v11H5V4Zm-2 5h2v11a2 2 0 0 0 2 2h11v2H7a2 2 0 0 1-2-2V9Z" />
          </svg>
        </button>
      </div>

      <pre class="cuadro-codigo"><code>{codigoPlantilla}</code></pre>
    </section>

    {esComparativaMergeVsQuick && (
      <section class="panel subpanel zona-comparativa">
        <h2><img src="/icons/network.svg" alt="" class="ui-icon" aria-hidden="true" />Comparativa interactiva: Merge Sort vs Quick Sort</h2>
        <p class="texto-suave">
          Haz clic en una cuadricula para abrir el algoritmo correspondiente y despues explora las metricas por tamano de arreglo,
          tipo de dato y escenario de entrada.
        </p>

        <div class="grilla-accesos">
          <a class="acceso-algoritmo merge" href="/programas-temporales/programa-21">
            <span class="etiqueta-algoritmo">Merge Sort (int)</span>
            <strong>Ir a implementacion</strong>
            <small>Programa temporal 21</small>
          </a>
          <a class="acceso-algoritmo quick" href="/programas-temporales/programa-07">
            <span class="etiqueta-algoritmo">Quick Sort (int)</span>
            <strong>Ir a implementacion</strong>
            <small>Actividad 07</small>
          </a>
        </div>

        <div class="controles-comparativa">
          <label>
            Longitud
            <select id="filtro-longitud">
              <option value="10">10 elementos</option>
              <option value="50">50 elementos</option>
              <option value="200">200 elementos</option>
            </select>
          </label>
          <label>
            Tipo de arreglo
            <select id="filtro-tipo">
              <option value="int">int</option>
              <option value="string">string</option>
            </select>
          </label>
          <label>
            Situacion
            <select id="filtro-escenario">
              <option value="desordenado">Desordenado</option>
              <option value="parcial">Parcialmente desordenado</option>
              <option value="invertido">Invertido</option>
            </select>
          </label>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla-comparativa" id="tabla-comparativa">
            <thead>
              <tr>
                <th>Metrica</th>
                <th>Merge Sort</th>
                <th>Quick Sort</th>
                <th>Ventaja</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla-comparativa" id="tabla-complejidad">
            <thead>
              <tr>
                <th>Analisis</th>
                <th>Merge Sort</th>
                <th>Quick Sort</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>

        <div class="paneles-analisis">
          <article class="panel-analisis">
            <h3>Ventajas destacadas</h3>
            <ul id="lista-ventajas"></ul>
          </article>
          <article class="panel-analisis">
            <h3>Desventajas / alertas</h3>
            <ul id="lista-desventajas"></ul>
          </article>
          <article class="panel-analisis">
            <h3>Recomendacion automatica</h3>
            <p id="texto-recomendacion"></p>
          </article>
        </div>

        <section class="panel-definiciones">
          <div class="selector-definicion" role="tablist" aria-label="Definiciones detalladas">
            <button type="button" class="tab-definicion activo" data-algoritmo="merge">Merge Sort</button>
            <button type="button" class="tab-definicion" data-algoritmo="quick">Quick Sort</button>
          </div>
          <article class="detalle-algoritmo" id="detalle-algoritmo"></article>
        </section>
      </section>
    )}

    <section class="panel subpanel zona-imagen">
      <h2><img src="/icons/flask.svg" alt="" class="ui-icon" aria-hidden="true" />Imagen de salida</h2>

      <div class="marco-imagen">
        <img
          id="imagen-salida-programa"
          src={programa.rutaImagenPlantilla}
          alt={`Imagen de salida de ${programa.titulo}`}
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>
  </main>

  <script is:inline>
    const datosComparativa = {
      int: {
        desordenado: {
          10: { merge: { tiempo: 0.07, comparaciones: 28, movimientos: 40, memoria: 6 }, quick: { tiempo: 0.05, comparaciones: 24, movimientos: 19, memoria: 2 } },
          50: { merge: { tiempo: 0.45, comparaciones: 276, movimientos: 438, memoria: 24 }, quick: { tiempo: 0.36, comparaciones: 251, movimientos: 184, memoria: 7 } },
          200: { merge: { tiempo: 2.21, comparaciones: 1540, movimientos: 2874, memoria: 95 }, quick: { tiempo: 1.66, comparaciones: 1394, movimientos: 980, memoria: 13 } }
        },
        parcial: {
          10: { merge: { tiempo: 0.06, comparaciones: 24, movimientos: 40, memoria: 6 }, quick: { tiempo: 0.04, comparaciones: 18, movimientos: 14, memoria: 2 } },
          50: { merge: { tiempo: 0.41, comparaciones: 249, movimientos: 438, memoria: 24 }, quick: { tiempo: 0.29, comparaciones: 190, movimientos: 133, memoria: 6 } },
          200: { merge: { tiempo: 2.05, comparaciones: 1462, movimientos: 2874, memoria: 95 }, quick: { tiempo: 1.31, comparaciones: 1116, movimientos: 715, memoria: 11 } }
        },
        invertido: {
          10: { merge: { tiempo: 0.07, comparaciones: 31, movimientos: 40, memoria: 6 }, quick: { tiempo: 0.11, comparaciones: 45, movimientos: 53, memoria: 8 } },
          50: { merge: { tiempo: 0.47, comparaciones: 289, movimientos: 438, memoria: 24 }, quick: { tiempo: 1.93, comparaciones: 1225, movimientos: 1290, memoria: 46 } },
          200: { merge: { tiempo: 2.24, comparaciones: 1601, movimientos: 2874, memoria: 95 }, quick: { tiempo: 22.8, comparaciones: 19900, movimientos: 20110, memoria: 189 } }
        }
      },
      string: {
        desordenado: {
          10: { merge: { tiempo: 0.11, comparaciones: 31, movimientos: 40, memoria: 7 }, quick: { tiempo: 0.09, comparaciones: 26, movimientos: 21, memoria: 3 } },
          50: { merge: { tiempo: 0.73, comparaciones: 295, movimientos: 438, memoria: 25 }, quick: { tiempo: 0.61, comparaciones: 266, movimientos: 196, memoria: 8 } },
          200: { merge: { tiempo: 3.12, comparaciones: 1658, movimientos: 2874, memoria: 97 }, quick: { tiempo: 2.61, comparaciones: 1488, movimientos: 1059, memoria: 15 } }
        },
        parcial: {
          10: { merge: { tiempo: 0.09, comparaciones: 26, movimientos: 40, memoria: 7 }, quick: { tiempo: 0.07, comparaciones: 21, movimientos: 16, memoria: 3 } },
          50: { merge: { tiempo: 0.68, comparaciones: 271, movimientos: 438, memoria: 25 }, quick: { tiempo: 0.53, comparaciones: 218, movimientos: 151, memoria: 7 } },
          200: { merge: { tiempo: 2.97, comparaciones: 1574, movimientos: 2874, memoria: 97 }, quick: { tiempo: 2.08, comparaciones: 1255, movimientos: 832, memoria: 12 } }
        },
        invertido: {
          10: { merge: { tiempo: 0.12, comparaciones: 34, movimientos: 40, memoria: 7 }, quick: { tiempo: 0.18, comparaciones: 52, movimientos: 60, memoria: 9 } },
          50: { merge: { tiempo: 0.77, comparaciones: 310, movimientos: 438, memoria: 25 }, quick: { tiempo: 2.41, comparaciones: 1270, movimientos: 1334, memoria: 50 } },
          200: { merge: { tiempo: 3.16, comparaciones: 1719, movimientos: 2874, memoria: 97 }, quick: { tiempo: 25.9, comparaciones: 20480, movimientos: 20644, memoria: 194 } }
        }
      }
    };

    const filtroLongitud = document.querySelector("#filtro-longitud");
    const filtroTipo = document.querySelector("#filtro-tipo");
    const filtroEscenario = document.querySelector("#filtro-escenario");
    const cuerpoTabla = document.querySelector("#tabla-comparativa tbody");
    const cuerpoTablaComplejidad = document.querySelector("#tabla-complejidad tbody");
    const listaVentajas = document.querySelector("#lista-ventajas");
    const listaDesventajas = document.querySelector("#lista-desventajas");
    const textoRecomendacion = document.querySelector("#texto-recomendacion");
    const tabsDefinicion = document.querySelectorAll(".tab-definicion");
    const detalleAlgoritmo = document.querySelector("#detalle-algoritmo");

    const metricas = [
      { clave: "tiempo", etiqueta: "Tiempo (ms)", menorEsMejor: true },
      { clave: "comparaciones", etiqueta: "Comparaciones", menorEsMejor: true },
      { clave: "movimientos", etiqueta: "Movimientos", menorEsMejor: true },
      { clave: "memoria", etiqueta: "Memoria extra estimada (KB)", menorEsMejor: true }
    ];

    const resolverGanador = (mergeValor, quickValor, menorEsMejor) => {
      if (mergeValor === quickValor) return "Empate";
      if (menorEsMejor) return mergeValor < quickValor ? "Merge Sort" : "Quick Sort";
      return mergeValor > quickValor ? "Merge Sort" : "Quick Sort";
    };

    const definicionesDetalladas = {
      merge: {
        titulo: "Merge Sort",
        funcionalidad: [
          "Divide recursivamente el arreglo en mitades hasta tener subarreglos de un elemento.",
          "Conquista mezclando subarreglos ya ordenados mediante comparacion secuencial.",
          "Mantiene orden estable: elementos iguales conservan su posicion relativa."
        ],
        ventajas: [
          "Complejidad temporal estable O(n log n) en mejor, promedio y peor caso.",
          "Excelente comportamiento en entradas invertidas o con patron adverso.",
          "Muy util para listas enlazadas y para ordenamiento externo en disco."
        ],
        desventajas: [
          "Requiere memoria auxiliar O(n) para el proceso de mezcla.",
          "Puede ser menos rapido que Quick Sort en arreglos pequenos en memoria RAM.",
          "Coste adicional de copiado/movimientos durante cada fase de merge."
        ]
      },
      quick: {
        titulo: "Quick Sort",
        funcionalidad: [
          "Selecciona un pivote y particiona el arreglo en menores/mayores al pivote.",
          "Ordena recursivamente ambos lados de la particion (divide y venceras).",
          "Su eficiencia depende de la calidad de las particiones logradas."
        ],
        ventajas: [
          "En promedio logra O(n log n) y suele ser muy rapido en practica.",
          "Uso de memoria auxiliar bajo (aprox. O(log n) por recursion promedio).",
          "Muy eficiente en arreglos en memoria cuando el pivote esta bien elegido."
        ],
        desventajas: [
          "Puede degradar a O(n²) en particiones muy desbalanceadas.",
          "No es estable por defecto (iguales pueden cambiar su orden relativo).",
          "Puede aumentar la profundidad de recursion en escenarios adversos."
        ]
      }
    };

    const complejidadesBase = {
      merge: { mejor: "O(n log n)", promedio: "O(n log n)", peor: "O(n log n)", memoria: "O(n)" },
      quick: { mejor: "O(n log n)", promedio: "O(n log n)", peor: "O(n²)", memoria: "O(log n) promedio / O(n) peor caso" }
    };

    const renderizarDefinicionAlgoritmo = (algoritmo) => {
      if (!detalleAlgoritmo) return;
      const datos = definicionesDetalladas[algoritmo];
      if (!datos) return;

      const listaHtml = (titulo, items) =>
        `<h4>${titulo}</h4><ol>${items.map((item) => `<li>${item}</li>`).join("")}</ol>`;

      detalleAlgoritmo.innerHTML = `
        <h3>${datos.titulo}: definicion detallada</h3>
        ${listaHtml("Funcionalidad del algoritmo", datos.funcionalidad)}
        ${listaHtml("Ventajas", datos.ventajas)}
        ${listaHtml("Desventajas", datos.desventajas)}
      `;
    };

    const renderizarComparativa = () => {
      if (!filtroLongitud || !filtroTipo || !filtroEscenario || !cuerpoTabla || !cuerpoTablaComplejidad || !listaVentajas || !listaDesventajas || !textoRecomendacion) return;

      const longitud = filtroLongitud.value;
      const tipo = filtroTipo.value;
      const escenario = filtroEscenario.value;
      const datos = datosComparativa[tipo]?.[escenario]?.[longitud];
      if (!datos) return;

      const merge = datos.merge;
      const quick = datos.quick;
      cuerpoTabla.innerHTML = "";

      let puntosMerge = 0;
      let puntosQuick = 0;
      const ventajas = [];
      const desventajas = [];

      metricas.forEach((metrica) => {
        const mergeValor = merge[metrica.clave];
        const quickValor = quick[metrica.clave];
        const ganador = resolverGanador(mergeValor, quickValor, metrica.menorEsMejor);
        const fila = document.createElement("tr");

        if (ganador === "Merge Sort") puntosMerge += 1;
        if (ganador === "Quick Sort") puntosQuick += 1;

        fila.innerHTML = `
          <td>${metrica.etiqueta}</td>
          <td>${mergeValor}</td>
          <td>${quickValor}</td>
          <td><span class="badge-ganador ${ganador === "Empate" ? "empate" : ganador === "Merge Sort" ? "merge" : "quick"}">${ganador}</span></td>
        `;
        cuerpoTabla.appendChild(fila);
      });

      const factorEscenario = escenario === "invertido" ? "alto" : escenario === "parcial" ? "medio" : "normal";
      const factorTipo = tipo === "string" ? "Comparacion lexicografica (costo adicional por longitud de texto)." : "Comparacion numerica directa.";
      cuerpoTablaComplejidad.innerHTML = `
        <tr>
          <td>Mejor caso</td>
          <td>${complejidadesBase.merge.mejor}</td>
          <td>${complejidadesBase.quick.mejor}</td>
        </tr>
        <tr>
          <td>Promedio</td>
          <td>${complejidadesBase.merge.promedio}</td>
          <td>${complejidadesBase.quick.promedio}</td>
        </tr>
        <tr>
          <td>Peor caso (situacion actual: ${escenario})</td>
          <td>${complejidadesBase.merge.peor}</td>
          <td>${escenario === "invertido" ? "Se aproxima a O(n²) con pivote simple." : complejidadesBase.quick.peor}</td>
        </tr>
        <tr>
          <td>Memoria adicional</td>
          <td>${complejidadesBase.merge.memoria}</td>
          <td>${complejidadesBase.quick.memoria}</td>
        </tr>
        <tr>
          <td>Contexto de ${longitud} elementos (${tipo})</td>
          <td>Rendimiento estable con factor ${factorEscenario}.</td>
          <td>${escenario === "invertido" ? "Particiones desfavorables elevan comparaciones." : "Buen rendimiento promedio con pivote favorable."}</td>
        </tr>
        <tr>
          <td>Tipo de dato seleccionado</td>
          <td>${factorTipo}</td>
          <td>${factorTipo}</td>
        </tr>
      `;

      if (quick.tiempo < merge.tiempo) {
        ventajas.push("Quick Sort domina en tiempo promedio en este escenario.");
      } else {
        ventajas.push("Merge Sort mantiene un tiempo estable incluso en casos exigentes.");
      }

      if (merge.memoria > quick.memoria) {
        desventajas.push("Merge Sort requiere memoria adicional para mezclar subarreglos.");
      } else if (quick.memoria > merge.memoria) {
        desventajas.push("Quick Sort aumenta profundidad de recursion y memoria en peores casos.");
      }

      if (escenario === "invertido") {
        desventajas.push("Con pivote simple, Quick Sort se acerca al peor caso O(n²) en arreglos invertidos.");
        ventajas.push("Merge Sort conserva complejidad O(n log n) sin importar el orden inicial.");
      } else {
        ventajas.push("Quick Sort aprovecha particiones favorables y reduce operaciones de movimiento.");
      }

      ventajas.push(`En ${tipo}, ambas soluciones escalan mejor en 50 y 200 elementos que algoritmos cuadraticos.`);

      listaVentajas.innerHTML = ventajas.map((item) => `<li>${item}</li>`).join("");
      listaDesventajas.innerHTML = desventajas.map((item) => `<li>${item}</li>`).join("");

      if (puntosMerge > puntosQuick) {
        textoRecomendacion.textContent = "Recomendacion: Merge Sort. En esta combinacion ofrece mejor balance global y mas estabilidad frente al peor caso.";
      } else if (puntosQuick > puntosMerge) {
        textoRecomendacion.textContent = "Recomendacion: Quick Sort. En esta combinacion logra mejor rendimiento promedio con menor costo operativo.";
      } else {
        textoRecomendacion.textContent = "Recomendacion: empate tecnico. Elige Merge Sort si priorizas estabilidad, o Quick Sort si priorizas rapidez promedio.";
      }
    };

    const botonCopiar = document.querySelector(".boton-copiar");
    const nodoCodigo = document.querySelector(".cuadro-codigo");
    filtroLongitud?.addEventListener("change", renderizarComparativa);
    filtroTipo?.addEventListener("change", renderizarComparativa);
    filtroEscenario?.addEventListener("change", renderizarComparativa);
    tabsDefinicion.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabsDefinicion.forEach((item) => item.classList.remove("activo"));
        tab.classList.add("activo");
        renderizarDefinicionAlgoritmo(tab.dataset.algoritmo ?? "merge");
      });
    });
    renderizarDefinicionAlgoritmo("merge");
    renderizarComparativa();

    botonCopiar?.addEventListener("click", async () => {
      if (!nodoCodigo) return;

      const texto = nodoCodigo.textContent ?? "";

      try {
        await navigator.clipboard.writeText(texto);
        botonCopiar.innerHTML = "✅";
        setTimeout(() => {
          botonCopiar.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2V7Zm2 0h9v11h-9V7Z" /><path d="M5 4a2 2 0 0 1 2-2h9v2H7v11H5V4Zm-2 5h2v11a2 2 0 0 0 2 2h11v2H7a2 2 0 0 1-2-2V9Z" /></svg>`;
        }, 1400);
      } catch {
        const seleccion = window.getSelection();
        const rango = document.createRange();
        rango.selectNodeContents(nodoCodigo);
        seleccion?.removeAllRanges();
        seleccion?.addRange(rango);
      }
    });
  </script>
</BaseLayout>

<style>
.programa-shell{
  max-width: 1260px;
  display: grid;
  gap: 1.1rem;
}

.encabezado-programa{
  display: grid;
  grid-template-columns: 110px 1fr auto;
  gap: 1.2rem;
  padding: 1.4rem;
  align-items: center;
}

.encabezado-programa > img{
  width: 100%;
  max-width: 110px;
  border-radius: .8rem;
  background: #fff;
  padding: 6px;
  border: 1px solid var(--line);
}

.encabezado-programa h1{
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  margin-bottom: .5rem;
}

.encabezado-programa p{ margin: 0; }

.icono-volver,
.boton-copiar{
  width: 3.7rem;
  height: 3.7rem;
  border-radius: .8rem;
  border: 1px solid var(--line);
  background: var(--panel);
  color: var(--text);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}


.icono-volver .ui-icon{
  margin-right: 0;
  width: 1.9rem;
  height: 1.9rem;
}

.icono-volver:hover,
.boton-copiar:hover{
  transform: translateY(-1px);
  border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
}

.encabezado-cuadro{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .7rem;
  margin-bottom: .8rem;
}

.encabezado-cuadro h2,
.zona-imagen h2{
  display: inline-flex;
  align-items: center;
  font-size: 1.5rem;
  margin: 0;
}

.cuadro-codigo{
  margin: 0;
  min-height: 460px;
  max-height: 460px;
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: .8rem;
  padding: 1rem;
  background: var(--panel);
  color: var(--text);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  font-size: 1rem;
  line-height: 1.55;
}


.marco-imagen{
  margin-top: .8rem;
  min-height: 460px;
  border-radius: .8rem;
  border: 1px solid var(--line);
  display: grid;
  place-items: center;
  overflow: hidden;
  padding: .6rem;
  background: var(--panel);
}

.marco-imagen img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: .6rem;
}

.zona-comparativa{
  display: grid;
  gap: 1rem;
}

.zona-comparativa h2{
  margin: 0;
  display: inline-flex;
  align-items: center;
}

.texto-suave{
  margin: 0;
  color: var(--text-soft, color-mix(in srgb, var(--text) 75%, white 25%));
}

.grilla-accesos{
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: .8rem;
}

.acceso-algoritmo{
  border: 1px solid var(--line);
  border-radius: .8rem;
  text-decoration: none;
  color: var(--text);
  padding: 1rem;
  display: grid;
  gap: .3rem;
  transition: transform .15s ease;
}

.acceso-algoritmo:hover{ transform: translateY(-2px); }
.acceso-algoritmo.merge{ background: color-mix(in srgb, #2dd4bf 17%, var(--panel)); }
.acceso-algoritmo.quick{ background: color-mix(in srgb, #f59e0b 17%, var(--panel)); }
.etiqueta-algoritmo{ font-size: .9rem; opacity: .85; }

.controles-comparativa{
